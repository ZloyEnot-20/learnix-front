# ── Production (copy to .env.production on the server) ─────────────────────
# NEXT_PUBLIC_API_URL=https://api.example.com/api
# BACKEND_URL=https://api.example.com
# PORT=3000

# ── Development (copy to .env.local) ───────────────────────────────────────
# Omit NEXT_PUBLIC_API_URL to use http://localhost:4000/api automatically.

# Public site URL — used for Open Graph previews (optional in dev).
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Client API base URL — must include /api suffix.
# NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Server rewrite target for /api/* — no /api suffix.
# Optional if NEXT_PUBLIC_API_URL is set (derived automatically).
# BACKEND_URL=http://localhost:4000
