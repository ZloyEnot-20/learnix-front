# Production env — copy to .env.production on the VPS before `pnpm build`.
# NEXT_PUBLIC_* values are inlined into the client bundle at build time.

# Public API URL (required). Must match backend CORS_ORIGINS + nginx.
NEXT_PUBLIC_API_URL=https://api.example.com/api

# Next.js /api rewrite target (optional — derived from NEXT_PUBLIC_API_URL).
BACKEND_URL=https://api.example.com

# next start port (default 3000)
PORT=3000
